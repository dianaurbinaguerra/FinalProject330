<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Security-Policy" content="default-src 'none'; connect-src 'self' http://localhost:3000;">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/recipe-s.css" />
    <link rel="stylesheet" href="/recipe-l.css" />
    <link
        href="https://fonts.googleapis.com/css2?family=Aleo:ital,wght@0,100..900;1,100..900&family=Fira+Sans:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Work+Sans:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <title>Meal Planner</title>
</head>
<body>
<div class="week-grid">

    <% Object.keys(planner).forEach(day=> { %>
        <div class="day-column">
            <h2>
                <%= day %>
            </h2>

            <% planner[day].forEach(meal=> { %>
                <div class="meal-card">
                    <img src="<%= meal.recipeImage %>" />
                    <p>
                        <%= meal.recipeName %>
                    </p>
                    <small>
                        <%= meal.mealType %>
                    </small>
                    <button onclick="removeMeal('<%= meal._id %>')">
                        Remove
                    </button>
                </div>
                <% }) %>

        </div>
        <% }) %>


</div>
</body>
</html>
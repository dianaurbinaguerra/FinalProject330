<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/recipe-s.css" />
    <link rel="stylesheet" href="/recipe-l.css" />
    <title>Meal Planner</title>
</head>
<script>
    async function removeMeal(mealId) {
        console.log("CLICKED DELETE:", mealId);

        const res = await fetch(`/api/user/meal-planner/${mealId}`, {
            method: "DELETE"
        });

        const data = await res.json();
        console.log(data);

        if (res.ok) {
            location.reload();
        } else {
            alert("Error deleting meal");
        }
    }
</script>
<body>
    <header>
        <picture id="logo">
            <img src="/images/LogoNameLarge.png" width="300" alt="recipenamelogo">
        </picture>
    </header>
<div class="week-grid">

    <% Object.keys(planner).forEach(day=> { %>
        <div class="day-column">
            <h2 class="weekday">
                <%= day %>
            </h2>

            <% planner[day].forEach(meal=> { %>
                <div class="meal-week-card">
                    <img src="<%= meal.recipeImage %>" />
                    <p id="recipe-week-name">
                        <%= meal.recipeName %>
                    </p>
                    <small>
                        <%= meal.mealType %>
                    </small>
                    <button onclick="removeMeal('<%= meal._id %>')">
                        Remove
                    </button>
                </div>
                <% }) %>

        </div>
        <% }) %>


</div>
<div class="back-to-home">
    <a href="/">Back to Home Page</a>
</div>
</body>
</html>
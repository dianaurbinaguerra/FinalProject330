<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="/recipe-s.css" />
        <link rel="stylesheet" href="/recipe-l.css" />
    <title>Document</title>
</head>
<script src="/js/recipe.js"></script>
<body>
    <header>
        <picture id="logo">
            <img src="/images/LogoNameLarge.png" width="300" alt="recipenamelogo">
        </picture>
    </header>

    <div class="recipe-container">
        <h1><%= recipe.title %></h1>
        <img src="<%= recipe.image %>" alt="<%= recipe.title %>"/>
        <h2>Ingredients:</h2>
        <ul>
            <% recipe.extendedIngredients.forEach(ingredient => { %>
                <li><%= ingredient.original %></li>
            <% }) %>
        </ul>
        <h2>Instructions:</h2>
        <ol>
            <% recipe.analyzedInstructions[0].steps.forEach(step => { %>
                <li><%= step.step %></li>
            <% }) %>
        </ol>
        <h2>Nutrition Facts</h2>
        
        <% if (nutrition && nutrition.totalNutrients) { %>
            <ul class="nutrition-list">
                <li>Calories: <%= nutrition.calories || "N/A" %>
                </li>
                <li>Fat: <%= nutrition.totalNutrients.FAT?.quantity?.toFixed(1) || 0 %> g</li>
                <li>Protein: <%= nutrition.totalNutrients.PROCNT?.quantity?.toFixed(1) || 0 %> g</li>
                <li>Carbs: <%= nutrition.totalNutrients.CHOCDF?.quantity?.toFixed(1) || 0 %> g</li>
            </ul>
            <% } else { %>
                <p>Nutrition data not available</p>
                <% } %>
        <div class="recipe-card">
            <select class="daySelect">
                <option>Monday</option>
                <option>Tuesday</option>
                <option>Wednesday</option>
                <option>Thursday</option>
                <option>Friday</option>
                <option>Saturday</option>
                <option>Sunday</option>
            </select>

            <select class="mealType">
                <option value="breakfast">Breakfast</option>
                <option value="lunch">Lunch</option>
                <option value="dinner">Dinner</option>
                <option value="snack">Snack</option>
            </select>

            <button onclick="saveMeal(
            '<%= recipe.id %>',
            '<%= recipe.title %>',
            '<%= recipe.image %>',
            this
        )">
                Save to My Meal Plan
            </button>
        </div>
    <div class="back-to-home">
            <a href="/">Back to Home Page</a>
    </div>
    </div>
</body>
</html>